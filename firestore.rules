rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'devotee';
    }
    
    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }
    
    function isCounselor() {
      return isAuthenticated() && getRole() == 'counselor';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isActiveUser() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && exists(path) && get(path).data.status == 'active';
    }

    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    // Users collection
    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || 
        isAdmin() || 
        (isCounselor() && (resource == null || resource.data.counselorUid == request.auth.uid))
      );
      allow create: if isAuthenticated() && isOwner(uid);
      allow write: if isAdmin();
      allow update: if isAuthenticated() && (
        isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'counselorUid', 'assignedDevotees'])
      ) || isAdmin();
      allow delete: if false;
    }

    // Preaching Sessions
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && getRole() == 'admin';
    }

    // Preaching Attendance
    match /attendance/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        (getRole() == 'admin' || getRole() == 'counselor');
    }

    // Legacy Attendance Sessions (admin attendance management)
    match /attendance_sessions/{sessionId} {
      allow read: if isActiveUser();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Legacy Attendance Records (admin attendance management)
    match /attendance_records/{recordId} {
      allow read: if isActiveUser();
      allow create: if isAdmin();
      allow update: if isAdmin() && 
        !get(/databases/$(database)/documents/attendance_sessions/$(resource.data.sessionId)).data.isLocked;
      allow delete: if false;
    }

    // Lectures
    match /lectures/{lectureId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    // Audio Tracks
    match /audio_tracks/{trackId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    // Japa Logs (per user)
    match /japa_logs/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Collection-group query on 'logs' sub-collection — admin only (for stats)
    match /{path=**}/logs/{logId} {
      allow read: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isActiveUser();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Assignments
    match /assignments/{assignmentId} {
      allow read: if isActiveUser();
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Assignment Submissions
    match /assignment_submissions/{submissionId} {
      allow read: if isAdmin() || (isActiveUser() && resource.data.studentUid == request.auth.uid);
      allow create: if isActiveUser() && request.resource.data.studentUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
